{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Usage",
  "version": "0.2.0",
  "identifier": "local.codex-usage.widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Codex Usage",
        "width": 960,
        "height": 416,
        "minWidth": 720,
        "minHeight": 416,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hexfeng/CodexUsageDashboard/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1NDQwRDE4RUM1OUE1MDMKUldRRHBWbnNHQTFFeFNaRmQ4WEtVUFlNd0daTXd4b0FqSDNVbmMrVkRLZ0phcUlEdnJYTDF6YmgK"
    }
  }
}
